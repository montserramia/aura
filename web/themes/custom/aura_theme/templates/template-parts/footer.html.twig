{#
/**
 * @file
 * Template per al footer del tema AURA
 * 
 * Estructura:
 * - Fila 1: Logo + AURA AI
 * - Fila 2: 3 columnes (Menu / Contacte / Legal)
 * - Fila 3: Copyright
 */
#}
<div class="footer-wrapper">
  <div class="footer-content">
    {# Fila 1: Logo #}
    <div class="footer-branding-row">
      <a href="{{ path('<front>') }}" class="footer-logo">
        <img src="{{ base_path ~ directory }}/aura-ai-logo-light.svg" alt="AURA AI" width="80">
      </a> <span class="footer-site-name">Consultoria d'Intel·ligència Artificial</span>
    </div>

    {# Fila 2: 3 Columnes #}
    <div class="footer-columns-row">
      {# Columna 1: Menu #}
      <div class="footer-column footer-menu">
        <h3 class="footer-heading">MENU</h3>
        <nav class="footer-nav" role="navigation">
          <ul class="footer-links">
            <li><a href="{{ path('<front>') }}">Inici</a></li>
            <li><a href="{{ path('<front>') }}#about">Sobre nosaltres</a></li>
            <li><a href="{{ path('<front>') }}#services">Serveis</a></li>
            <li><a href="{{ path('/blog') }}#resources">Recursos</a></li>
            <li><a href="{{ path('/contacte') }}#contact">Contacte</a></li>
          </ul>
        </nav>
      </div>

      {# Columna 2: Contacte #}
      <div class="footer-column footer-contact">
        <h3 class="footer-heading">CONTACT</h3>
        <address class="footer-address">
          <p>Avinguda Constiució 197,</p>
          <p>Castelldefels, BCN 08860</p>
          <p>Mail: <a href="mailto:hola@aura-ia.eu">hola@aura-ia.eu</a></p>
          <p>Tel: 674 93 33 94</p>
        </address>
      </div>

      {# Columna 3: Legal #}
      <div class="footer-column footer-legal">
        <h3 class="footer-heading">LEGAL</h3>
        <ul class="footer-legal-links">
          <li><a href="{{ path('<front>') }}privacy-policy">Privacy Policy</a></li>
          <li><a href="{{ path('<front>') }}accessibility-statement">Accessibility Statement</a></li>
        </ul>
      </div>
    </div>

    {# Fila 3: Copyright #}
    <div class="footer-bottom-row">
        © {{ "now"|date("Y") }} by AURA AI.
    </div>
  </div>
</div>
