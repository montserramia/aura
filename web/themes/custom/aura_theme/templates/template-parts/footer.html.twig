{#
/**
 * @file
 * Template per al footer del tema AURA
 * 
 * Estructura:
 * - Fila 1: Logo + AURA AI
 * - Fila 2: 3 columnes (Menu / Contacte / Legal)
 * - Fila 3: Copyright
 */
#}
<div class="footer-wrapper">
  <div class="footer-content">
    {# Fila 1: Logo #}
    <div class="footer-branding-row">
      <a href="{{ path('<front>') }}" class="footer-logo">
        <img src="{{ base_path ~ directory }}/aura-ai-logo-light.svg" alt="AURA AI" width="80">
      </a> <span class="footer-site-name">{{ 'Artificial Intelligence Consulting'|t }}</span>
    </div>

    {# Fila 2: 3 Columnes #}
    <div class="footer-columns-row">
      {# Columna 1: Menu #}
      <div class="footer-column footer-menu">
        <h3 class="footer-heading">{{ 'MENU'|t }}</h3>
        <nav class="footer-nav" role="navigation">
          <ul class="footer-links">
            <li><a href="/">{{ 'Home'|t }}</a></li>
            <li><a href="/quisoc">{{ 'About us'|t }}</a></li>
            <li><a href="/services">{{ 'Services'|t }}</a></li>
            <li><a href="/blog">{{ 'Resources'|t }}</a></li>
            <li><a href="#contacte">{{ 'Contact'|t }}</a></li>
          </ul>
        </nav>
      </div>

      {# Columna 2: Contacte #}
      <div class="footer-column footer-contact">
        <h3 class="footer-heading">{{ 'CONTACT'|t }}</h3>
        <address class="footer-address">
          <p>{{ 'Constitution Avenue 197,'|t }}</p>
          <p>{{ 'Castelldefels, BCN 08860'|t }}</p>
          <p>{{ 'Email:'|t }} <a href="mailto:hola@aura-ia.eu">hola@aura-ia.eu</a></p>
          <p>{{ 'Phone:'|t }} 674 93 33 94</p>
        </address>
      </div>

      {# Columna 3: Legal #}
      <div class="footer-column footer-legal">
        <h3 class="footer-heading">{{ 'LEGAL'|t }}</h3>
        <ul class="footer-legal-links">
          <li><a href="/privacy-policy">{{ 'Privacy Policy'|t }}</a></li>
          <li><a href="/accessibilitat">{{ 'Accessibility Statement'|t }}</a></li>
        </ul>
      </div>
    </div>

    {# Fila 3: Copyright #}
    <div class="footer-bottom-row">
      <span class="footer-copyright">
        © {{ "now"|date("Y") }} {{ 'by AURA AI.'|t }} | {{ 'Developed and maintained by'|t }} <a href="https://newwweb.cat/" target="_blank" rel="noopener">newWweb</a>
      </span>
    </div>
  </div>
</div>
