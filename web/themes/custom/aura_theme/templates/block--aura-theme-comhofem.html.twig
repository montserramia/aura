{#
  Custom block: AURA com ho fem (machine name aura_theme_comhofem).
  Full-width video background with 4-step grid and CTA.
#}
<section id="aura-theme-comhofem" class="aura-comhofem" aria-labelledby="aura-comhofem-title">
  <video
    class="aura-comhofem__bg"
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true">
    <source src="{{ file_url('themes/custom/aura_theme/video/comhofem-bg.webm') }}" type="video/mp4">
  </video>
  <div class="aura-comhofem__overlay" aria-hidden="true"></div>

  <div class="aura-comhofem__inner">
    <div class="aura-comhofem__header">
      <div>
        <h2 id="aura-comhofem-title">{{ 'How can AI benefit your project, step by step'|t }}</h2>
        <p class="aura-comhofem__subtitle">{{ 'A process designed to help you move from idea to execution.'|t }}</p>
      </div>
      <a class="aura-comhofem__cta" href="#contacte">{{ 'SHALL WE TALK ABOUT YOUR CASE?'|t }}</a>
    </div>
  </div>
  
  <div>
    <div class="aura-comhofem__grid" role="list">
      <div class="aura-comhofem__item" role="listitem">
        <div class="aura-comhofem__item-head">
          <div class="aura-comhofem__badge">A</div>
          <div class="aura-comhofem__item-top">
            <h3 class="aura-comhofem__item-title">{{ 'ANALYSIS'|t }}</h3>
          </div>
        </div>
        <p class="aura-comhofem__item-body">
        <p class="aura-comhofem__item-lead">{{ 'Real value starts here'|t }}</p>
        <strong>{{ 'Understand your context before talking about AI'|t }}</strong> 
        {{ 'Before applying any technology, we analyze your project: processes, workloads, and the points where time, clarity, or efficiency can truly be gained.'|t }}</strong>
        </p>
        <a class="aura-comhofem__ghost" href="#contacte">{{ 'Learn more'|t }}</a>
      </div>

      <div class="aura-comhofem__item" role="listitem">
        <div class="aura-comhofem__item-head">
          <div class="aura-comhofem__badge">U</div>
          <div class="aura-comhofem__item-top">
            <h3 class="aura-comhofem__item-title">{{ 'STRATEGIC USE'|t }}</h3>
          </div>
        </div>
        <p class="aura-comhofem__item-body">
        <p class="aura-comhofem__item-lead">{{ 'Technology adapts to the project'|t }}</p>
          <strong>{{ 'Decide how AI can help you (and how it cannot)'|t }}</strong> {{ "We define how to use AI in alignment with your goals. No automation for automation's sake, and no unnecessary dependencies."|t }}
        </p>
        <a class="aura-comhofem__ghost" href="#contacte">{{ 'We show you how'|t }}</a>
      </div>

      <div class="aura-comhofem__item" role="listitem">
        <div class="aura-comhofem__item-head">
          <div class="aura-comhofem__badge">R</div>
          <div class="aura-comhofem__item-top">
            <h3 class="aura-comhofem__item-title">{{ 'OPERATIONAL RESULTS'|t }}</h3>
          </div>
        </div>
        <p class="aura-comhofem__item-body">
        <p class="aura-comhofem__item-lead">{{ 'Move from idea to real implementation'|t }}</p>
        <strong>{{ 'Now AI becomes a useful tool'|t }}</strong> {{ 'We implement solutions that work in your environment: more agile processes, better information management, and real decision-making support.'|t }}
        </p>
        <a class="aura-comhofem__ghost" href="#contacte">{{ "Let's think together"|t }}</a>
      </div>

      <div class="aura-comhofem__item" role="listitem">
        <div class="aura-comhofem__item-head">
          <div class="aura-comhofem__badge">A</div>
          <div class="aura-comhofem__item-top">
            <h3 class="aura-comhofem__item-title">{{ 'CONTINUOUS ADAPTATION'|t }}</h3>
          </div>
        </div>
        <p class="aura-comhofem__item-body">
        <p class="aura-comhofem__item-lead">{{ 'Sustainable results, no fireworks'|t }}</p>
        <strong>{{ 'Make AI evolve with your project'|t }}</strong> {{ 'We adjust and improve as the project grows. AI is not a one-time installation, but support that adapts to changing reality.'|t }}
        </p>
        <a class="aura-comhofem__ghost" href="#contacte">{{ 'Now is the time!'|t }}</a>
      </div>
    </div>
  </div>
</section>
