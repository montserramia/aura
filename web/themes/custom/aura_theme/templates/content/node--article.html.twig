{#
/**
 * @file
 * Template per articles del blog AURA
 * 
 * Disseny minimalista tipus "pàgina de paper":
 * - Fons clar overlay
 * - Contingut centrat amb marge
 * - Autor i data sobre el títol
 * - Títol dins del "paper"
 * - Peu amb compartir, estadístiques i comentaris
 */
#}
{%
set node_classes = [
  'node',
  'node-article',
  node.isPromoted() ? 'node-promoted',
  node.isSticky() ? 'node-sticky',
  not node.isPublished() ? 'node-unpublished',
  view_mode ? 'node-view-mode-' ~ view_mode|clean_class,
]
%}

<article{{ attributes.addClass(node_classes) }}>
  {{ title_prefix }}
  
  {# Header de l'article: autor, data i títol #}
  <header class="article-header">
    {% if display_submitted %}
      <div class="article-meta">
        {% if node_author_pic %}
          <div class="author-picture">{{ author_picture }}</div>
        {% endif %}
        <div class="article-meta-details">
          {% set createdDate = node.getCreatedTime|date('j F Y') %}
          <span class="author-name">
            <i class="icon-user"></i> {{ author_name }}
          </span>
          <span class="publish-date">
            <i class="icon-calendar"></i> {{ createdDate }}
          </span>
        </div>
      </div>
    {% endif %}
    
    {% if not page %}
      <h1{{ title_attributes.addClass('article-title') }}>
        <a href="{{ url }}" rel="bookmark">{{ label }}</a>
      </h1>
    {% else %}
      <h1{{ title_attributes.addClass('article-title') }}>{{ label }}</h1>
    {% endif %}
    
  </header>
  
  {{ title_suffix }}

  {# Cos de l'article #}
  <div{{ content_attributes.addClass('article-content') }}>
    {{ content }}
  </div>
  
  {# Peu de l'article: compartir, estadístiques, articles relacionats #}
  <footer class="article-footer">
    {# Secció Compartir #}
    <section class="article-share">
      <h3 class="share-title">{{ 'Compartir'|t }}</h3>
      <div class="share-buttons">
        {# Facebook #}
        <button class="share-btn share-facebook" onclick="window.open('https://www.facebook.com/sharer/sharer.php?u={{ url }}', '', 'width=600,height=400')" aria-label="{{ 'Compartir a Facebook'|t }}">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </button>
        
        {# X (Twitter) #}
        <button class="share-btn share-x" onclick="window.open('https://twitter.com/intent/tweet?url={{ url }}&text={{ label }}', '', 'width=600,height=400')" aria-label="{{ 'Compartir a X'|t }}">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </button>
        
        {# LinkedIn #}
        <button class="share-btn share-linkedin" onclick="window.open('https://www.linkedin.com/shareArticle?mini=true&url={{ url }}&title={{ label }}', '', 'width=600,height=400')" aria-label="{{ 'Compartir a LinkedIn'|t }}">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </button>
        
        {# Enllaç #}
        <button class="share-btn share-link" onclick="navigator.clipboard.writeText('{{ url }}');alert('{{ 'Enllaç copiat al porta-retalls'|t }}')" aria-label="{{ 'Copiar enllaç'|t }}">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="currentColor" d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
          </svg>
        </button>
        
        {# Imprimir #}
        <button class="share-btn share-print" onclick="window.print()" aria-label="{{ 'Imprimir'|t }}">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="currentColor" d="M19 8h-1V3H6v5H5c-1.66 0-3 1.34-3 3v6h3v4h14v-4h3v-6c0-1.66-1.34-3-3-3zM8 5h8v3H8V5zm8 12v2H8v-4h8v2zm2-2v-2H6v2H4v-4c0-.55.45-1 1-1h14c.55 0 1 .45 1 1v4h-2z"/>
            <circle cx="18" cy="11.5" r="1" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </section>
    
    {# Secció Estadístiques #}
    <section class="article-stats">
      <div class="stat-item stat-views">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="currentColor" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
        </svg>
        <span class="stat-count">0</span>
        <span class="stat-label">{{ 'Visualitzacions'|t }}</span>
      </div>
      
      <div class="stat-item stat-comments">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="currentColor" d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18zM18 14H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
        </svg>
        <span class="stat-count">0</span>
        <span class="stat-label">{{ 'Comentaris'|t }}</span>
      </div>
      
      <div class="stat-item stat-like">
        <button class="like-btn" aria-label="M'agrada">
          <svg class="like-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path fill="currentColor" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          <span class="like-count">0</span>
        </button>
      </div>
    </section>

    {# Tags/Categories si existeixen #}
    {% if content.field_tags %}
      <div class="article-tags">
        {% for item in content.field_tags %}
          {% if item['#title'] %}
            <a href="{{ item['#url']}}" class="tag-link">{{ item['#title'] }}</a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
    
    {# Articles relacionats #}
    <section class="related-articles" data-hook="recent-posts">
      <div class="related-header">
        <h3 class="related-title">{{ 'Entrades relacionades'|t }}</h3>
        <a href="#" class="related-all">{{ 'Ver todo'|t }}</a>
      </div>
      <div class="related-grid">
        {# Aquí es carregarien els articles relacionats dinàmicament #}
        {# Placeholder per Drupal #}
      </div>
    </section>
    
    {# Comentaris #}
    <section class="article-comments">
      <h3 class="comments-title">{{ 'Comentaris'|t }}</h3>
      <div class="comment-form-wrapper">
        {{ content.comments }}
      </div>
    </section>
  </footer>
</article>
