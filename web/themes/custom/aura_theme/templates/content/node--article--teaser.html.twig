{#
/**
 * @file
 * Template per articles en mode Resum (teaser)
 * 
 * Mostra:
 * - Data relativa (fa X dies)
 * - Temps de lectura
 * - Títol amb alçada fixa
 * - Comptador de comentaris
 * - Botó de compartir (opcional)
 */
#}
{%
set node_classes = [
  'node',
  'node-article',
  'node-article-teaser',
  node.isPromoted() ? 'node-promoted',
  node.isSticky() ? 'node-sticky',
  not node.isPublished() ? 'node-unpublished',
  view_mode ? 'node-view-mode-' ~ view_mode|clean_class,
]
%}

<article{{ attributes.addClass(node_classes) }}>
  {{ title_prefix }}
  
  {# Meta: data relativa i temps de lectura #}
  <div class="article-teaser-meta">
    <span class="article-teaser-date" title="{{ node.getCreatedTime|date('j F Y') }}">
      {{ relative_date }}
    </span>
    <span class="article-teaser-separator">·</span>
    <span class="article-teaser-readtime">
      {{ reading_time }} min de lectura
    </span>
  </div>
  
  {# Títol amb alçada fixa #}
  <h2 class="article-teaser-title">
    <a href="{{ url }}" rel="bookmark">{{ label }}</a>
  </h2>
  
  {# Peu: comentaris i compartir #}
  <footer class="article-teaser-footer">
    <div class="article-teaser-comments">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <path fill="currentColor" d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18zM18 14H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
      </svg>
      <span class="comment-count">
        {{ comment_count }}
      </span>
    </div>
    
    {# Botó de compartir (opcional) #}
    <div class="article-teaser-share">
      <button class="share-toggle" aria-label="Compartir" aria-expanded="false">
        <svg viewBox="0 0 19 19" width="19" height="19" aria-hidden="true">
          <path fill="currentColor" d="M2.44398805,5.99973295 C1.62345525,5.9690612 0.980075653,5.28418875 1.00047182,4.46312144 C1.02086799,3.64205413 1.69745853,2.98998831 2.51850166,3.0001164 C3.33954478,3.01024449 3.99985313,3.67880182 4,4.50012255 C3.98424812,5.34399206 3.28763905,6.0153508 2.44398805,5.99973295 L2.44398805,5.99973295 Z M2.44398805,10.9997329 C1.62345525,10.9690612 0.980075653,10.2841888 1.00047182,9.46312144 C1.02086799,8.64205413 1.69745853,7.98998831 2.51850166,8.0001164 C3.33954478,8.01024449 3.99985313,8.67880182 4,9.50012255 C3.98424812,10.3439921 3.28763905,11.0153508 2.44398805,10.9997329 L2.44398805,10.9997329 Z M2.44398805,15.9997329 C1.62345525,15.9690612 0.980075653,15.2841888 1.00047182,14.4631214 C1.02086799,13.6420541 1.69745853,12.9899883 2.51850166,13.0001164 C3.33954478,13.0102445 3.99985313,13.6788018 4,14.5001225 C3.98424812,15.3439921 3.28763905,16.0153508 2.44398805,15.9997329 L2.44398805,15.9997329 Z"/>
        </svg>
      </button>
      <div class="share-options" hidden>
        <button class="share-option share-facebook" onclick="window.open('https://www.facebook.com/sharer/sharer.php?u={{ url }}', '', 'width=600,height=400')" aria-label="Compartir a Facebook">
          <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </button>
        <button class="share-option share-x" onclick="window.open('https://twitter.com/intent/tweet?url={{ url }}&text={{ label }}', '', 'width=600,height=400')" aria-label="Compartir a X">
          <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </button>
        <button class="share-option share-linkedin" onclick="window.open('https://www.linkedin.com/shareArticle?mini=true&url={{ url }}&title={{ label }}', '', 'width=600,height=400')" aria-label="Compartir a LinkedIn">
          <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </button>
        <button class="share-option share-link" onclick="navigator.clipboard.writeText('{{ url }}');alert('Enllaç copiat al porta-retalls')" aria-label="Copiar enllaç">
          <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
        </button>
      </div>
    </div>
  </footer>
</article>

{{ title_suffix }}
