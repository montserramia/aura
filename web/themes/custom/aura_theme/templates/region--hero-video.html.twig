{#
  Custom hero region with inverted video background.
  Shows the theme video (hero.mp4) inverted via CSS; content is overlaid.
#}
<section class="section-dark aura-video-hero">
  <video
    class="aura-video-bg"
    src="{{ file_url('themes/custom/aura_theme/video/hero-1.webm') }}"
    poster="{{ file_url('themes/custom/aura_theme/images/      {% set poster_fallback = background_video_poster|default(base_path ~ 'themes/custom/aura_theme/images/20260318182325.png') %}
.png') }}"
    autoplay
    muted
    loop
    playsinline
    aria-label="Hero background video">
  </video>
  <div class="aura-video-overlay"></div>
  {% if content %}
    <div class="aura-video-content">
      {{ content }}
    </div>
  {% endif %}
</section>
