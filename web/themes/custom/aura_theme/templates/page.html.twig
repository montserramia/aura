{#
/**
 * @file
 * Template principal per AURA
 */
#}
<div class="page-wrapper">
  <header class="site-header" role="banner">
    {{ page.header }}
    {% if page.primary_menu %}
      <nav id="primary-navigation" class="primary-navigation" role="navigation">
        {{ page.primary_menu }}
      </nav>
    {% endif %}
    <button class="mobile-menu-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  {% if page.hero_video %}
    {{ page.hero_video }}
  {% elseif page.hero %}
    <section class="hero-region">
      {{ page.hero }}
    </section>
  {% endif %}

  <main class="main-content" role="main">
    <section>
      {% if page.highlighted %}
        <div class="highlighted region-highlighted">
          {{ page.highlighted }}
        </div>
      {% endif %}
      {% if page.content_above %}
        <div class="content-above">{{ page.content_above }}</div>
      {% endif %}
      <div class="content-wrapper">
        {{ page.content }}
      </div>
      {% if page.content_below %}
        <div class="content-below">{{ page.content_below }}</div>
      {% endif %}
    </section>

    {# Footer sempre visible #}
    <div class="site-footer" role="contentinfo">
      {% include '@aura_theme/template-parts/footer.html.twig' %}
    </div>
    
  </main>

</div>
