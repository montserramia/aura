{# Front page override to ensure AURA layout applies on homepage #}
<div class="page-wrapper">
  <header class="site-header" role="banner">
    {{ page.header }}
    {% if page.primary_menu %}
      <nav id="primary-navigation" class="primary-navigation" role="navigation">
        {{ page.primary_menu }}
      </nav>
    {% endif %}
    <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="primary-navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  {% if page.hero %}
    <section class="hero-region">
      {{ page.hero }}
    </section>
  {% endif %}

  {# Banner full width #}
  {% if page.banner %}
    <section class="banner-region">
      {{ page.banner }}
    </section>
  {% endif %}

  <main class="main-content" role="main">
    <section>
      {% if page.highlighted %}
        <div class="highlighted">{{ page.highlighted }}</div>
      {% endif %}

      {% if page.content_above %}
        <div class="content-above">{{ page.content_above }}</div>
      {% endif %}

      <div class="content-wrapper">
        {{ page.content }}
      </div>

      {% if page.content_below %}
        <div class="content-below">{{ page.content_below }}</div>
      {% endif %}
    </section>

    {# Footer sempre visible #}
    <div class="site-footer" role="contentinfo">
      {% include '@aura_theme/template-parts/footer.html.twig' %}
    </div>
    
  </main>

  <button class="scroll-to-top" aria-label="Tornar a dalt" title="Tornar a dalt">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

</div>